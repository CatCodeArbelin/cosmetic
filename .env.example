# App
APP_NAME=cosmetic-support
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Telegram bot (manager)
BOT_TOKEN=your_bot_token
MANAGER_CHAT_ID=123456789
OPERATOR_IDS=111111111,222222222

# Telegram account (store account for Pyrogram)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
PYROGRAM_SESSION_NAME=cosmetic_client
TELEGRAM_PHONE=+10000000000
TELEGRAM_SERVICE_BOT_ID=777000
TELEGRAM_SESSION_DIR=/app/app/sessions

# AI / OpenAI
AI_ENABLED=false
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Database / PostgreSQL
POSTGRES_DB=cosmetic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cosmetic

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Debounce
INCOMING_DEBOUNCE_SECONDS=7
